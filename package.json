{
  "name": "canvas-rich",
  "version": "0.1.0",
  "description": "GPU 自绘的 canvas 富文本编辑内核：字形 → 图集 → GPU 贴图四边形，不依赖 DOM 排版。A GPU-rendered rich text editor engine on HTML canvas (WebGL2/WebGPU).",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "go-xworks",
  "homepage": "https://github.com/go-xworks/canvas-rich#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/go-xworks/canvas-rich.git"
  },
  "bugs": {
    "url": "https://github.com/go-xworks/canvas-rich/issues"
  },
  "keywords": [
    "rich-text-editor",
    "canvas",
    "webgl",
    "webgpu",
    "gpu",
    "text-rendering",
    "glyph-atlas",
    "harfbuzz",
    "bidi",
    "typescript",
    "editor",
    "wysiwyg"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json",
    "build:demo": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.examples.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.70",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "bidi-js": "^1.0.3",
    "harfbuzzjs": "^1.2.1",
    "katex": "^0.17.0",
    "tailwindcss": "^4.3.0"
  }
}
