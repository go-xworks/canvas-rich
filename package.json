{
  "name": "canvas-rich-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "pnpm --filter @canvas-rich/website dev",
    "dev:demo": "pnpm --filter @canvas-rich/demo dev",
    "build": "pnpm --filter canvas-rich build",
    "build:pages": "pnpm --filter @canvas-rich/website build && pnpm --filter @canvas-rich/demo build",
    "build:demo": "pnpm run build:pages",
    "preview": "pnpm --filter @canvas-rich/website preview",
    "preview:demo": "pnpm --filter @canvas-rich/demo preview",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint .",
    "format": "oxfmt --write packages apps",
    "format:check": "oxfmt --check packages apps",
    "test": "pnpm --filter canvas-rich test",
    "test:watch": "pnpm --filter canvas-rich test:watch"
  },
  "devDependencies": {
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  },
  "engines": {
    "node": ">=20"
  }
}
